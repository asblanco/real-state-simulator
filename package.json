{
  "name": "real-state-simulator",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "preview": "vite preview",
    "test": "bun test",
    "test:e2e": "bun run preview -- --port 8080 & SERVER_PID=$!; sleep 2 && bun test e2e/; kill $SERVER_PID 2>/dev/null",
    "sync": "bun run build && bunx browser-sync start --server dist --files 'dist/**/*' --no-notify --no-open"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.65.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/bun": "latest",
    "browser-sync": "^3.0.4",
    "svelte": "^5.56.3",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "chart.js": "^4.5.1",
    "daisyui": "5",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.3.0"
  }
}
